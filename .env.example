# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcg_career_services

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=careerservices@mcgcollege.com

# PandaDoc
PANDADOC_API_KEY=your-pandadoc-api-key
PANDADOC_WEBHOOK_SECRET=your-pandadoc-webhook-secret

# Integration Mode: 'mock' or 'live'
INTEGRATION_MODE=mock

# Server
PORT=5000
NODE_ENV=development
